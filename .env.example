# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── OANDA (forex data) ────────────────────────────────
# Get yours at: https://developer.oanda.com
OANDA_API_KEY=
# Practice: https://api-fxpractice.oanda.com/v3
# Live: https://api-fxtrade.oanda.com/v3
OANDA_API_URL=https://api-fxpractice.oanda.com/v3

# ── News API (sentiment) ──────────────────────────────
# Get yours at: https://newsapi.org
NEWS_API_KEY=
NEWS_ENABLED=true

# ── Database ──────────────────────────────────────────
# SQLite (default, no server needed):
# DATABASE_URL=sqlite+aiosqlite:///./forex_signal.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/forex_signal
DATABASE_URL=sqlite+aiosqlite:///./forex_signal.db

# ── Runtime ──────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO

# ── Analysis defaults ────────────────────────────────
DEFAULT_TIMEFRAME=1h
DEFAULT_PERIOD_DAYS=90
CACHE_TTL_SECONDS=300
USER_DAILY_LIMIT=100

# ── Broadcast scheduler ──────────────────────────────
BROADCAST_ENABLED=true
BROADCAST_MAX_PAIRS=5

# ── Risk management defaults ─────────────────────────
DEFAULT_ACCOUNT_BALANCE=10000
DEFAULT_RISK_PERCENT=2.0
MAX_DRAWDOWN_PERCENT=20.0
